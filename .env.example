# ============================================================
#  ISKO BARBERS — Environment Variables
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit your real .env file to Git.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Session Secret ──────────────────────────────────────────
# Change this to any long random string before going live.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Admin Credentials ───────────────────────────────────────
# Used to seed the default admin account on first run.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=iskobarbers2025

# ── Email (Gmail SMTP) ───────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to myaccount.google.com → Security → App Passwords.
# 3. Generate an App Password and paste it below.
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-gmail-app-password
